{
  "name": "sjtu-course-downloader",
  "version": "2.2.2",
  "description": "批量下载 SJTU v.sjtu 旁听、Canvas、好大学在线课程资源的 Electron 桌面应用，支持本地下载与直传交大云盘（需连接 SJTU 校园网或交大 VPN）",
  "main": "out/main/index.js",
  "author": "SJTU Course Downloader Contributors",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/run-electron-vite.mjs dev",
    "build": "node scripts/run-electron-vite.mjs build && electron-builder",
    "build:unpack": "node scripts/run-electron-vite.mjs build && electron-builder --dir",
    "build:win": "node scripts/run-electron-vite.mjs build && electron-builder --win",
    "build:mac": "node scripts/run-electron-vite.mjs build && electron-builder --mac",
    "build:linux": "node scripts/run-electron-vite.mjs build && electron-builder --linux",
    "icons": "node scripts/generate-icons.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json --composite false && tsc --noEmit -p tsconfig.web.json --composite false"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "cheerio": "^1.2.0",
    "ffmpeg-static": "^5.3.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^7.0.0",
    "zustand": "^5.0.2"
  },
  "build": {
    "appId": "edu.sjtu.course-downloader",
    "productName": "SJTU 课程下载器",
    "artifactName": "sjtu-course-downloader-${version}-${os}-${arch}.${ext}",
    "directories": {
      "buildResources": "build",
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "extraResources": [
      {
        "from": "build/icons",
        "to": "icons",
        "filter": [
          "**/*.png"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "msi"
      ],
      "icon": "build/icons/icon.ico"
    },
    "mac": {
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icons/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico"
    },
    "msi": {
      "oneClick": false,
      "perMachine": false,
      "runAfterFinish": true,
      "warningsAsErrors": false,
      "additionalLightArgs": ["-cultures:zh-CN"]
    }
  }
}
